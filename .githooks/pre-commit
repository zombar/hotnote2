#!/bin/sh

# --- Dependency check ---
if ! [ -f "node_modules/.bin/eslint" ]; then
    echo "✖ Dev dependencies missing. Run: make setup"
    exit 1
fi

# --- Version stamp ---
SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
TS=$(node -e "process.stdout.write(String(Date.now()))" 2>/dev/null \
    || python3 -c "import time; print(int(time.time()*1000))" 2>/dev/null \
    || echo "0")
printf '{"sha":"%s","ts":%s}\n' "$SHA" "$TS" > version.json
sed -i.bak "s/^const CACHE = .*/const CACHE = 'hotnote-${SHA}';/" sw.js && rm -f sw.js.bak
git add version.json sw.js

# --- Lint staged JS files only ---
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.js$' || true)
if [ -n "$STAGED_JS" ]; then
    echo "→ ESLint..."
    echo "$STAGED_JS" | xargs node_modules/.bin/eslint || {
        echo "✖ ESLint failed. Run 'make lint' for full details."
        exit 1
    }
fi

# --- Duplicate detection (full js/ scan) ---
echo "→ jscpd..."
node_modules/.bin/jscpd js/ || {
    echo "✖ jscpd: duplication exceeds threshold. Run 'make dupes' for details."
    exit 1
}
